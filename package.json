{
  "name": "jannal",
  "version": "0.2.4",
  "description": "Intercept, visualize, and optimize LLM context windows. Proxy that sits between your AI tools and the Anthropic API.",
  "main": "electron/main.js",
  "scripts": {
    "test:tokens": "node scripts/test-tokens.js",
    "dev:server": "node server.js",
    "dev:ui": "vite",
    "build": "vite build",
    "start": "node server.js",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:build": "vite build && electron-builder --mac",
    "electron:build:all": "vite build && electron-builder --mac --win --linux",
    "test": "node --test test/router-recall.test.js test/session-hash.test.js"
  },
  "keywords": [
    "llm",
    "context-window",
    "proxy",
    "anthropic",
    "claude",
    "token-optimization",
    "inspector",
    "developer-tools"
  ],
  "author": "Arvind Naidu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Buzzie-AI/jannal"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "electron-updater": "^6.3.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^8.0.0"
  },
  "build": {
    "appId": "com.buzzie.jannal",
    "productName": "Jannal",
    "copyright": "Copyright © 2026 Arvind Naidu",
    "publish": {
      "provider": "github",
      "owner": "Buzzie-AI",
      "repo": "jannal"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "title": "Jannal",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icons"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "lib/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "server.js",
      "lib/**/*",
      "public/**/*",
      "node_modules/**/*"
    ]
  }
}
